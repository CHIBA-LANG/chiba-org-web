---
import { getCollection } from 'astro:content';
import BentoCard from './BentoCard.astro';
import SectionFrame from './SectionFrame.astro';
import SectionIntro from './SectionIntro.astro';
import { extractMarkdownDescription, extractMarkdownTitle } from '../utils/content';

const priorityDocIds = ['README', 'chibalex', 'chibacc', 'memory-model'];
const allDocs = await getCollection('chiba_level1_spec');
const docsById = new Map(allDocs.map((entry) => [entry.id, entry]));
const docs = priorityDocIds.flatMap((id) => {
  const entry = docsById.get(id);
  return entry ? [entry] : [];
}).map((entry) => ({
  ...entry,
  computedTitle: entry.data.title ?? extractMarkdownTitle(entry.body, entry.id),
  computedDescription: entry.data.description ?? extractMarkdownDescription(entry.body),
}));

function truncate(str: string, max = 110) {
  return str.length <= max ? str : str.slice(0, max).trimEnd() + '…';
}
---

<SectionFrame innerClass="grid grid-cols-1 lg:grid-cols-[1.1fr_1.9fr] gap-0" variant="transparent">
  <SectionIntro
    label="[ DOCS / LEVEL-1 SPEC ]"
    title="Language Spec Surface"
    href="/docs/"
    cta="Browse Docs"
    class="bg-[linear-gradient(180deg,rgba(0,230,118,0.08),transparent_65%),var(--color-chiba-container)]"
  >
    <div class="space-y-3 mb-6 text-sm leading-relaxed">
      <p class="text-muted">新的 docs 区已经接入站内，面向 CHIBA level-1 的核心语言、控制流、内存模型、包系统与 lowering 规则。</p>
      <p class="text-subtle">A site-native entry into the CHIBA level-1 spec, so readers can browse implementation-facing language rules without leaving the main site.</p>
    </div>
  </SectionIntro>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
    {docs.map((doc) => (
      <a href={`/docs/${doc.id}/`} class="block h-full">
        <BentoCard class="bg-surface-low group cursor-pointer hover:border-chiba-green/30 transition-colors h-full !p-0 overflow-hidden flex flex-col border-y border-line md:border-l first:md:border-l-0">
          <div class="flex flex-col flex-1 p-4">
            <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-subtle mb-3 border-b border-line pb-3">
              LEVEL-1 DOC
            </div>
            <h3 class="text-base font-space font-bold mb-2 group-hover:text-chiba-green transition-colors leading-tight uppercase tracking-[-0.02em]">
              {doc.computedTitle}
            </h3>
            <p class="text-xs text-muted leading-relaxed mb-2">{truncate(doc.computedDescription)}</p>
            <p class="text-xs text-subtle leading-relaxed mb-4">Follow the current CHIBA language rule and jump into the full section from the landing page.</p>
            <div class="text-[10px] text-subtle font-bold uppercase tracking-[0.18em] flex items-center gap-1 group-hover:gap-2 transition-all mt-auto pt-4 border-t border-line">
              Open Doc
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </div>
        </BentoCard>
      </a>
    ))}
  </div>
</SectionFrame>
