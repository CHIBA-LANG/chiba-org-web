---
import SectionFrame from './SectionFrame.astro';

const pillars = [
  {
    no: '01',
    title: 'NATIVE',
    desc: 'No LLVM. No libc. Proprietary self-hosting native backend.',
    detail: 'Every instruction emitted with binary precision.',
    sigil: '┌─┐',
  },
  {
    no: '02',
    title: 'FUNCTIONAL',
    desc: 'ADTs, row polymorphism, first-class continuations.',
    detail: 'Composition without compromise.',
    sigil: '├─┤',
  },
  {
    no: '03',
    title: 'VERIFIED',
    desc: 'Answer Type tracks continuation boundaries.',
    detail: 'Safety without GC, without refcount.',
    sigil: '└─┘',
    href: '/type_system',
    cta: 'TYPE SYSTEM',
  },
];
---

<SectionFrame innerClass="grid grid-cols-1 md:grid-cols-3 gap-0" variant="transparent">
  {pillars.map((p, i) => (
    <article class={`relative bg-surface p-8 group hover:bg-surface-low transition-colors ${i < 2 ? 'md:border-r border-line' : ''} border-y border-line`}>
      <div class="flex items-baseline justify-between mb-6">
        <span class="font-mono text-[11px] tracking-[0.3em] text-subtle">[{p.no}]</span>
        <span class="font-mono text-xs text-chiba-line group-hover:text-chiba-green transition-colors">{p.sigil}</span>
      </div>

      <h3 class="font-sans text-3xl font-bold tracking-[-0.02em] uppercase leading-none mb-5 text-chiba-text">
        {p.title}
      </h3>

      <p class="font-mono text-sm text-muted leading-relaxed mb-6">
        {p.desc}
      </p>

      <div class="font-mono text-[11px] text-subtle border-t border-line pt-4 flex items-center gap-2">
        <span class="text-chiba-green">▍</span>
        <span class="italic">{p.detail}</span>
      </div>

      {p.href && p.cta && (
        <a
          href={p.href}
          class="mt-6 inline-flex items-center gap-2 border border-line px-4 py-3 font-mono text-[11px] font-semibold uppercase tracking-[0.2em] text-chiba-green hover:text-chiba-text hover:border-chiba-green/40 hover:bg-surface transition-colors"
        >
          <span>{p.cta}</span>
          <span>-></span>
        </a>
      )}
    </article>
  ))}
</SectionFrame>
