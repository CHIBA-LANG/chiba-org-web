---
import BentoCard from './BentoCard.astro';
import SectionFrame from './SectionFrame.astro';

const faqs = [
  { q: 'Tail-Call Opt.', a: 'ATP proves stack depth bounds at compile-time.' },
  { q: 'Uniqueness', a: 'Tracks resources through function boundaries.' },
  { q: 'No LLVM', a: 'Built for deterministic cycle-by-cycle control.' },
  { q: 'Continuations', a: 'Parser resumes from valid sync points locally.' },
];
---

<SectionFrame innerClass="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-0" variant="transparent">
  {faqs.map((f, index) => (
    <BentoCard class={`bg-surface-low/50 border-y border-line ${index < faqs.length - 1 ? 'lg:border-r md:border-r-0' : ''}`}>
      <div class="flex items-center justify-between mb-4 border-b border-line pb-3">
        <h4 class="font-mono text-[11px] font-bold text-chiba-green uppercase tracking-[0.2em]">{f.q}</h4>
        <span class="font-mono text-[10px] text-subtle">0{index + 1}</span>
      </div>
      <p class="text-xs text-subtle leading-relaxed font-medium">{f.a}</p>
    </BentoCard>
  ))}
</SectionFrame>
