---
interface Props {
  href: string;
  variant?: 'text' | 'primary' | 'secondary';
  class?: string;
}

const { href, variant = 'text', class: className = '' } = Astro.props;

const variants = {
  text: 'text-chiba-green hover:text-chiba-text border-b border-chiba-green/30 pb-1',
  primary: 'bg-chiba-green text-chiba-bg hover:bg-chiba-text px-6 py-4',
  secondary: 'border border-line text-chiba-green hover:bg-chiba-green/10 px-6 py-4',
};
---

<a
  href={href}
  class={`inline-flex items-center gap-2 font-mono text-xs font-bold uppercase tracking-[0.2em] transition-colors ${variants[variant]} ${className}`}
>
  <slot />
  <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <line x1="5" y1="12" x2="19" y2="12" />
    <polyline points="12 5 19 12 12 19" />
  </svg>
</a>
