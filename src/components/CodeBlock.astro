---
import BentoCard from './BentoCard.astro';
import Label from './Label.astro';

const chibaHL = [
  `<span class="tok-comment">// Store a 64-bit word at ptr[idx] (idx in 8-byte units). Returns 0.</span>`,
  `<span class="tok-keyword">def</span> <span class="tok-fn">store64</span><span class="tok-punct">(</span><span class="tok-param">ptr</span><span class="tok-punct">:</span> <span class="tok-type">i64</span><span class="tok-punct">,</span> <span class="tok-param">idx</span><span class="tok-punct">:</span> <span class="tok-type">i64</span><span class="tok-punct">,</span> <span class="tok-param">val</span><span class="tok-punct">:</span> <span class="tok-type">i64</span><span class="tok-punct">):</span> <span class="tok-punct">*</span><span class="tok-type">u8</span> <span class="tok-punct">=</span>`,
  `    <span class="tok-keyword">asm</span> <span class="tok-punct">(</span><span class="tok-param">ptr</span><span class="tok-punct">:</span> <span class="tok-reg">rdi</span><span class="tok-punct">,</span> <span class="tok-param">idx</span><span class="tok-punct">:</span> <span class="tok-reg">rsi</span><span class="tok-punct">,</span> <span class="tok-param">val</span><span class="tok-punct">:</span> <span class="tok-reg">rdx</span><span class="tok-punct">)</span> <span class="tok-punct">:</span> <span class="tok-punct">(</span><span class="tok-reg">rax</span><span class="tok-punct">)</span> <span class="tok-punct">=&gt;</span> <span class="tok-punct">{</span>`,
  `        <span class="tok-string">"mov [rdi + rsi*8], rdx"</span>`,
  `        <span class="tok-string">"xor eax, eax"</span>`,
  `    <span class="tok-punct">}</span>`,
].join('\n');

const asmHL = [
  `<span class="tok-placeholder">&lt;prefix&gt;</span><span class="tok-punct">_</span><span class="tok-fn">store64</span><span class="tok-punct">:</span>`,
  `    <span class="tok-placeholder">&lt;abi calling convention&gt;</span>`,
  `    <span class="tok-instr">mov</span> <span class="tok-punct">[</span><span class="tok-reg">rdi</span> <span class="tok-punct">+</span> <span class="tok-reg">rsi</span><span class="tok-punct">*</span><span class="tok-num">8</span><span class="tok-punct">],</span> <span class="tok-reg">rdx</span>`,
  `    <span class="tok-instr">xor</span> <span class="tok-reg">eax</span><span class="tok-punct">,</span> <span class="tok-reg">eax</span>`,
  `    <span class="tok-placeholder">&lt;abi return sequence&gt;</span>`,
  `    <span class="tok-instr">jmp</span> <span class="tok-placeholder">&lt;the continuation address&gt;</span>`,
].join('\n');
---

<section class="col-span-1 md:col-span-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
  <BentoCard class="lg:col-span-2 bg-black">
    <div class="flex justify-between items-center mb-6">
      <Label>store64.chiba</Label>
      <div class="flex gap-2">
        <div class="w-2 h-2 rounded-full bg-red-500/50"></div>
        <div class="w-2 h-2 rounded-full bg-yellow-500/50"></div>
        <div class="w-2 h-2 rounded-full bg-chiba-green/50"></div>
      </div>
    </div>
    <pre class="font-mono text-[13px] leading-relaxed overflow-x-auto whitespace-pre"><code set:html={chibaHL} /></pre>
  </BentoCard>
  <BentoCard class="bg-chiba-container-low">
    <Label>Emitted ASM</Label>
    <pre class="font-mono text-[11px] overflow-x-auto whitespace-pre"><code set:html={asmHL} /></pre>
    <div class="mt-8 flex flex-col gap-2">
      <div class="bg-chiba-green/5 px-3 py-2 rounded-full text-[10px] text-chiba-green font-bold uppercase tracking-widest flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Zero Runtime symbols
      </div>
      <div class="bg-white/5 px-3 py-2 rounded-full text-[10px] text-chiba-gray font-bold uppercase tracking-widest flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Static mapping
      </div>
    </div>
  </BentoCard>
</section>
