---
import { getCollection } from 'astro:content';
import BentoCard from './BentoCard.astro';
import Label from './Label.astro';
import FormattedDate from './FormattedDate.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

function truncate(str: string, max = 80) {
  return str.length <= max ? str : str.slice(0, max).trimEnd() + '…';
}
---

<section class="col-span-1 md:col-span-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
  <div class="lg:col-span-1 py-4">
    <h2 class="text-3xl font-space font-bold tracking-tighter uppercase mb-2">Latest Insights</h2>
    <p class="text-sm text-chiba-gray font-medium mb-6">Tracking the frontier of deterministic systems.</p>
    <a
      href="/blog"
      class="flex items-center gap-2 text-xs font-bold text-chiba-green uppercase tracking-widest hover:text-white transition-colors"
    >
      View All Posts
      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>

  <div class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-4">
    {posts.map((post) => (
      <a href={`/blog/${post.id}`} class="block h-full">
        <BentoCard class="bg-chiba-container-low group cursor-pointer hover:border-chiba-green/30 transition-all h-full !p-0 overflow-hidden flex flex-col">
          {post.data.heroImage && (
            <div class="w-full h-36 overflow-hidden shrink-0">
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </div>
          )}
          <div class="flex flex-col flex-1 p-4">
              <FormattedDate date={post.data.pubDate} />
            <h3 class="text-base font-space font-bold mb-2 group-hover:text-chiba-green transition-colors leading-tight">
              {post.data.title}
            </h3>
            {post.data.description && (
              <p class="text-xs text-chiba-text-dim leading-relaxed mb-4">{truncate(post.data.description)}</p>
            )}
            <div class="text-[10px] text-chiba-gray font-bold uppercase tracking-widest flex items-center gap-1 group-hover:gap-2 transition-all mt-auto">
              Read Article
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </div>
        </BentoCard>
      </a>
    ))}
  </div>
</section>
