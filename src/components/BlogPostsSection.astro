---
import { getCollection } from 'astro:content';
import SectionFrame from './SectionFrame.astro';
import FormattedDate from './FormattedDate.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

// Stages = synthetic intro/outro frames + every post.
// The IntersectionObserver swaps the sticky stage when each frame enters view.
type Stage = {
  id: string;
  eyebrow: string;
  title: string;
  description: string;
  cover: string;
  href: string;
  cta: string;
  accent: string;
  pubDate?: Date;
};

const stages: Stage[] = [
  {
    id: 'about',
    eyebrow: '[ LOG / INSIGHTS ]',
    title: 'Latest Insights',
    description: 'Compiler notes, proof sketches, backend experiments, and deterministic systems logs — read the manifesto behind it.',
    cover: '/about-cover.png',
    href: '/about/',
    cta: 'About / Manifesto',
    accent: 'manifesto',
  },
  ...posts.map((post): Stage => ({
    id: post.id,
    eyebrow: '[ POST / BLOG ]',
    title: post.data.title,
    description: post.data.description ?? '',
    cover: post.data.heroImage ?? '/about-cover.png',
    href: `/blog/${post.id}/`,
    cta: 'Read Article',
    accent: 'log',
    pubDate: post.data.pubDate,
  })),
];

const initial = stages[0];
---

<SectionFrame innerClass="grid grid-cols-1 lg:grid-cols-3 gap-0" variant="transparent">
  <!-- ── LEFT: sticky stage ─────────────────────────────────────────── -->
  <div
    class="lg:col-span-1 relative border-y border-line bg-surface"
    data-insights-root
  >
    <div class="lg:sticky lg:top-24 lg:self-start" data-insights-stage>
      <!-- click-through wrapper -->
      <a
        href={initial.href}
        class="group block focus:outline-none focus-visible:ring-2 focus-visible:ring-chiba-green"
        data-stage-link
        aria-label="Active insight"
      >
        <!-- cover image (12:9 landscape) -->
        <div class="relative w-full aspect-12/9 overflow-hidden border-b border-line bg-chiba-bg">
          <img
            src={initial.cover}
            alt=""
            aria-hidden="true"
            class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500"
            data-stage-cover
          />
          <div class="absolute inset-0 bg-linear-to-t from-surface/70 via-transparent to-transparent pointer-events-none"></div>

          <!-- corner markers -->
          <div class="absolute left-3 top-3 font-mono text-[9px] uppercase tracking-[0.24em] text-chiba-text/80 pointer-events-none">[ CHIBA / 尺八 ]</div>
          <div class="absolute right-3 top-3 font-mono text-[9px] uppercase tracking-[0.24em] text-chiba-green flex items-center gap-1.5 pointer-events-none">
            <span class="w-1 h-1 bg-chiba-green inline-block pulse"></span>
            <span data-stage-accent>{initial.accent}</span>
          </div>
          <div class="absolute left-3 bottom-3 font-mono text-[9px] uppercase tracking-[0.24em] text-chiba-gray pointer-events-none">
            <span data-stage-counter>01 / {String(stages.length).padStart(2, '0')}</span>
          </div>
        </div>

        <!-- copy -->
        <div class="py-6 px-6">
          <div class="font-mono text-[11px] tracking-[0.28em] text-subtle mb-3" data-stage-eyebrow>{initial.eyebrow}</div>
          <h2
            class="text-2xl md:text-3xl font-space font-bold tracking-[-0.04em] uppercase mb-3 leading-[1.05] group-hover:text-chiba-green transition-colors"
            data-stage-title
          >
            {initial.title}
          </h2>
          <p class="text-sm text-muted leading-relaxed font-medium mb-5" data-stage-description>
            {initial.description}
          </p>

          <div class="mt-auto flex items-center justify-between gap-3 pt-4 border-t border-line">
            <span class="inline-flex items-center gap-2 font-mono text-[11px] font-bold uppercase tracking-[0.18em] text-chiba-green group-hover:gap-3 transition-all">
              <span data-stage-cta>{initial.cta}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-subtle">scroll ▾</span>
          </div>
        </div>
      </a>
    </div>
  </div>

  <!-- ── RIGHT: scrolling list ──────────────────────────────────────── -->
  <div class="lg:col-span-2 border-y border-line">
    {stages.map((stage, i) => (
      <article
        data-insights-frame
        data-stage-index={i}
        data-cover={stage.cover}
        data-eyebrow={stage.eyebrow}
        data-title={stage.title}
        data-description={stage.description}
        data-href={stage.href}
        data-cta={stage.cta}
        data-accent={stage.accent}
        class={`group/frame relative border-b border-line last:border-b-0 md:border-l ${i === 0 ? 'bg-surface-low' : 'bg-surface'} px-6 md:px-8 py-8 md:py-10 transition-colors`}
      >
        <div class="flex items-baseline justify-between gap-3 font-mono text-[10px] uppercase tracking-[0.22em] text-subtle mb-5">
          <span>{stage.eyebrow}</span>
          <span class="text-chiba-gray">{String(i + 1).padStart(2, '0')} / {String(stages.length).padStart(2, '0')}</span>
        </div>

        <!-- horizontal row: small cover + text -->
        <div class="flex flex-col sm:flex-row gap-5 sm:gap-6 items-stretch">
          <a
            href={stage.href}
            class="shrink-0 block w-full sm:w-44 md:w-56 aspect-12/9 overflow-hidden border border-line bg-chiba-bg relative"
            aria-hidden="true"
            tabindex="-1"
          >
            <img
              src={stage.cover}
              alt=""
              class="absolute inset-0 w-full h-full object-cover grayscale group-hover/frame:grayscale-0 transition-[filter,transform] duration-500 group-hover/frame:scale-[1.02]"
            />
            <div class="absolute inset-0 bg-linear-to-t from-chiba-bg/40 via-transparent to-transparent pointer-events-none"></div>
          </a>

          <div class="flex flex-col min-w-0 flex-1">
            <h3 class="text-xl md:text-2xl font-space font-bold tracking-[-0.03em] uppercase leading-[1.1] mb-3">
              <a
                href={stage.href}
                class="hover:text-chiba-green transition-colors"
              >{stage.title}</a>
            </h3>

            {stage.description && (
              <p class="text-sm text-muted leading-relaxed font-medium mb-5 line-clamp-3">{stage.description}</p>
            )}

            <div class="mt-auto flex items-center justify-between gap-3 pt-4 border-t border-line/60 font-mono text-[10px] uppercase tracking-[0.18em]">
              <a
                href={stage.href}
                class="inline-flex items-center gap-1 text-chiba-green font-bold hover:gap-2 transition-all"
              >
                {stage.cta}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              {stage.pubDate && (
                <span class="text-subtle">
                  <FormattedDate date={stage.pubDate} />
                </span>
              )}
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</SectionFrame>

<script>
  // sticky scroll stage — swap left cover + copy as the right column scrolls through frames
  const root = document.querySelector<HTMLElement>('[data-insights-root]');
  if (root) {
    const frames = Array.from(document.querySelectorAll<HTMLElement>('[data-insights-frame]'));
    const stageLink = document.querySelector<HTMLAnchorElement>('[data-stage-link]');
    const coverEl = document.querySelector<HTMLImageElement>('[data-stage-cover]');
    const eyebrowEl = document.querySelector<HTMLElement>('[data-stage-eyebrow]');
    const titleEl = document.querySelector<HTMLElement>('[data-stage-title]');
    const descEl = document.querySelector<HTMLElement>('[data-stage-description]');
    const ctaEl = document.querySelector<HTMLElement>('[data-stage-cta]');
    const accentEl = document.querySelector<HTMLElement>('[data-stage-accent]');
    const counterEl = document.querySelector<HTMLElement>('[data-stage-counter]');
    const total = frames.length;

    let activeIdx = -1;
    const setActive = (idx: number) => {
      if (idx === activeIdx) return;
      activeIdx = idx;
      const f = frames[idx];
      if (!f) return;

      // fade cover
      if (coverEl) {
        const nextSrc = f.dataset.cover ?? '';
        if (coverEl.src.endsWith(nextSrc) === false) {
          coverEl.style.opacity = '0';
          // small timeout so the transition is visible
          window.setTimeout(() => {
            coverEl.src = nextSrc;
            coverEl.style.opacity = '1';
          }, 180);
        }
      }
      if (eyebrowEl) eyebrowEl.textContent = f.dataset.eyebrow ?? '';
      if (titleEl) titleEl.textContent = f.dataset.title ?? '';
      if (descEl) descEl.textContent = f.dataset.description ?? '';
      if (ctaEl) ctaEl.textContent = f.dataset.cta ?? '';
      if (accentEl) accentEl.textContent = f.dataset.accent ?? '';
      if (stageLink) stageLink.href = f.dataset.href ?? '#';
      if (counterEl) {
        counterEl.textContent =
          String(idx + 1).padStart(2, '0') + ' / ' + String(total).padStart(2, '0');
      }

      // visual marker on the active frame
      frames.forEach((fr, i) => {
        fr.classList.toggle('bg-surface-low', i === idx);
        fr.classList.toggle('bg-surface', i !== idx);
      });
    };

    // a thin band in the middle of the viewport decides "active"
    const io = new IntersectionObserver(
      (entries) => {
        // pick the entry closest to the band center
        const visible = entries
          .filter((e) => e.isIntersecting)
          .map((e) => ({ idx: Number((e.target as HTMLElement).dataset.stageIndex), ratio: e.intersectionRatio }));
        if (visible.length) {
          visible.sort((a, b) => b.ratio - a.ratio);
          setActive(visible[0].idx);
        }
      },
      { rootMargin: '-40% 0px -40% 0px', threshold: [0, 0.25, 0.5, 1] }
    );
    frames.forEach((f) => io.observe(f));

    // initialize to the first frame in view (covers the case where the section is already mid-viewport on load)
    requestAnimationFrame(() => {
      const winCenter = window.innerHeight / 2;
      let best = 0;
      let bestDist = Infinity;
      frames.forEach((f, i) => {
        const r = f.getBoundingClientRect();
        const c = (r.top + r.bottom) / 2;
        const d = Math.abs(c - winCenter);
        if (d < bestDist) {
          bestDist = d;
          best = i;
        }
      });
      setActive(best);
    });
  }
</script>
