---
import BaseLayout from './BaseLayout.astro';
import ArticleToc from '../components/ArticleToc.astro';

interface Props {
  title: string;
  description: string;
  slug: string;
  previousSpec?: {
    title: string;
    href: string;
  };
  nextSpec?: {
    title: string;
    href: string;
  };
}

const SITE_URL = 'https://chiba-lang.org';
const { title, description, slug, previousSpec, nextSpec } = Astro.props;
const canonicalUrl = `${SITE_URL}/type_system/${slug}/`;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': `${canonicalUrl}#techarticle`,
  headline: title,
  description,
  url: canonicalUrl,
  mainEntityOfPage: canonicalUrl,
  about: ['CHIBA type system', 'programming language type systems'],
  author: { '@type': 'Organization', name: 'CHIBA Software Foundation', url: SITE_URL },
  publisher: { '@type': 'Organization', name: 'CHIBA Software Foundation', url: SITE_URL },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Type System', item: `${SITE_URL}/type_system/` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  canonicalUrl={canonicalUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <main class="max-w-[1400px] mx-auto px-6 md:px-10 pt-32 pb-24">
    <div class="flex gap-8 items-start justify-center">
      <ArticleToc />

      <div class="w-full max-w-5xl">
        <div class="mb-10 border border-chiba-line bg-chiba-container">
          <header class="px-6 md:px-8 pt-6 pb-8 border-b border-chiba-line">
            <div class="text-[10px] font-mono font-bold uppercase tracking-[0.24em] text-chiba-gray mb-4">
              CHIBA / TYPE SYSTEM / SPEC
            </div>
            <h1 class="font-space text-4xl md:text-6xl font-bold tracking-[-0.04em] uppercase text-chiba-text leading-[0.95] mb-4">
              {title}
            </h1>
            <div class="max-w-3xl space-y-3 text-chiba-text-dim leading-relaxed">
              <p>类型系统文档区用于集中整理 CHIBA level-1 的类型规则、边界定义与实现约束，保持设计与实现之间的可追踪关系。</p>
              <p>Type system notes centralize CHIBA level-1 typing rules, boundary decisions, and implementation constraints so the design stays auditable end to end.</p>
            </div>
          </header>

          <article class="px-6 md:px-8 py-8">
            <div class="prose" data-article-content>
              <slot />
            </div>
          </article>
        </div>

        <nav class="grid grid-cols-1 md:grid-cols-3 gap-3" aria-label="Type system navigation">
          <a
            href="/type_system/"
            class="border border-chiba-line bg-chiba-container px-4 py-4 text-xs font-bold uppercase tracking-[0.18em] text-chiba-green hover:text-chiba-text hover:border-chiba-green/30 transition-colors"
          >
            Type System Index
          </a>
          {previousSpec && (
            <a
              href={previousSpec.href}
              class="border border-chiba-line bg-chiba-container px-4 py-4 text-xs uppercase tracking-[0.12em] text-chiba-text-dim hover:text-chiba-green hover:border-chiba-green/30 transition-colors"
            >
              <span class="block text-[10px] font-bold text-chiba-gray mb-2 tracking-[0.18em]">Previous</span>
              {previousSpec.title}
            </a>
          )}
          {nextSpec && (
            <a
              href={nextSpec.href}
              class="border border-chiba-line bg-chiba-container px-4 py-4 text-xs uppercase tracking-[0.12em] text-chiba-text-dim hover:text-chiba-green hover:border-chiba-green/30 transition-colors md:text-right"
            >
              <span class="block text-[10px] font-bold text-chiba-gray mb-2 tracking-[0.18em]">Next</span>
              {nextSpec.title}
            </a>
          )}
        </nav>
      </div>
    </div>
  </main>
</BaseLayout>