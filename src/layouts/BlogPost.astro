---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ArticleToc from '../components/ArticleToc.astro';

type RelatedPost = {
  title: string;
  href: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
  slug: string;
  previousPost?: RelatedPost;
  nextPost?: RelatedPost;
};

const SITE_URL = 'https://chiba-lang.org';
const DEFAULT_OG_IMAGE = `${SITE_URL}/og-default.png`;

const { title, description, pubDate, updatedDate, heroImage, ogImage, slug, previousPost, nextPost } = Astro.props;

const postUrl = `${SITE_URL}/blog/${slug}/`;
const resolvedOgImage = ogImage ?? (heroImage ? SITE_URL + heroImage : DEFAULT_OG_IMAGE);
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog/` },
    { '@type': 'ListItem', position: 3, name: title, item: postUrl },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage={resolvedOgImage}
  canonicalUrl={postUrl}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      '@id': `${postUrl}#blogposting`,
      headline: title,
      description,
      image: resolvedOgImage,
      url: postUrl,
      mainEntityOfPage: postUrl,
      datePublished: pubDate.toISOString(),
      dateModified: (updatedDate ?? pubDate).toISOString(),
      author: { '@type': 'Organization', name: 'CHIBA' },
      publisher: {
        '@type': 'Organization',
        name: 'CHIBA Software Foundation',
        url: SITE_URL,
      },
    })}
  />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <main class="max-w-[1400px] mx-auto px-6 md:px-10 pt-32 pb-24">
    {heroImage && (
      <img
        class="w-full max-w-5xl mx-auto h-[320px] md:h-[420px] object-cover mb-10 border border-chiba-line"
        src={heroImage}
        alt={title}
      />
    )}

    <div class="flex gap-8 items-start justify-center">
      <ArticleToc />

      <div class="w-full max-w-5xl">
        <div class="mb-10 border border-chiba-line bg-chiba-container">
          <header class="px-6 md:px-8 pt-6 pb-8 border-b border-chiba-line">
            <div class="text-[10px] font-mono font-bold uppercase tracking-[0.22em] text-chiba-gray mb-4 border-b border-chiba-line pb-4">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="ml-3 text-chiba-green/60">
                  Updated: <FormattedDate date={updatedDate} />
                </span>
              )}
            </div>
            <h1 class="font-space text-4xl md:text-6xl font-bold tracking-[-0.04em] uppercase text-chiba-text leading-[0.95] mb-4">
              {title}
            </h1>
            {description && (
              <p class="text-lg text-chiba-text-dim leading-relaxed max-w-3xl">{description}</p>
            )}
          </header>

          <article class="px-6 md:px-8 py-8">
            <div class="prose" data-article-content>
              <slot />
            </div>
          </article>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-chiba-line max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <a
          href="/blog/"
          class="border border-chiba-line bg-chiba-container px-4 py-4 text-xs font-bold uppercase tracking-[0.18em] text-chiba-green hover:text-chiba-text hover:border-chiba-green/30 transition-colors"
        >
          All Posts
        </a>
        {previousPost && (
          <a
            href={previousPost.href}
            class="border border-chiba-line bg-chiba-container px-4 py-4 text-xs uppercase tracking-[0.12em] text-chiba-text-dim hover:text-chiba-green hover:border-chiba-green/30 transition-colors"
          >
            <span class="block text-[10px] font-bold text-chiba-gray mb-2 tracking-[0.18em]">Previous</span>
            {previousPost.title}
          </a>
        )}
        {nextPost && (
          <a
            href={nextPost.href}
            class="border border-chiba-line bg-chiba-container px-4 py-4 text-xs uppercase tracking-[0.12em] text-chiba-text-dim hover:text-chiba-green hover:border-chiba-green/30 transition-colors md:text-right"
          >
            <span class="block text-[10px] font-bold text-chiba-gray mb-2 tracking-[0.18em]">Next</span>
            {nextPost.title}
          </a>
        )}
      </div>
    </div>
  </main>

  <footer class="border-t border-chiba-line py-8 text-center">
    <p class="text-[10px] text-chiba-gray uppercase tracking-widest">
      © {new Date().getFullYear()} CHIBA Software Foundation
    </p>
  </footer>
</BaseLayout>
