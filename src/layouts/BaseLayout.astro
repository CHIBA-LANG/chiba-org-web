---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  canonicalUrl?: string;
  keywords?: string;
}

const SITE_URL = 'https://chiba-lang.org';
const DEFAULT_OG_IMAGE = `${SITE_URL}/CHIBA.png`;

const {
  title,
  description = SITE_DESCRIPTION,
  ogType = 'website',
  ogImage = DEFAULT_OG_IMAGE,
  canonicalUrl = Astro.url.href,
  keywords = 'Chiba, functional programming, systems programming, compiler, assembly, zero runtime, algebraic data types, continuations, row polymorphism, Rust, Zig, C++, C, Ocaml, Haskell, memory safety, deterministic',
} = Astro.props;

const fullTitle = title === SITE_TITLE ? title : `${title} — ${SITE_TITLE}`;
const resolvedCanonicalUrl = new URL(canonicalUrl, SITE_URL).href;
const isHomePage = new URL(resolvedCanonicalUrl).pathname === '/';

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'CHIBA',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Linux, macOS, Windows',
  description: SITE_DESCRIPTION,
  url: SITE_URL,
  image: DEFAULT_OG_IMAGE,
  softwareVersion: '0.6.13',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Person',
    name: 'LemonHX',
    url: SITE_URL,
  },
  license: 'https://opensource.org/licenses/Apache-2.0',
};
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'CHIBA',
  url: SITE_URL,
  description: SITE_DESCRIPTION,
  publisher: {
    '@type': 'Organization',
    name: 'CHIBA Software Foundation',
    url: SITE_URL,
    logo: `${SITE_URL}/CHIBA.png`,
    sameAs: ['https://github.com/chiba-lang', 'https://x.com/lemonhxmoe'],
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="LemonHX" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={resolvedCanonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_TITLE} Blog`} href={`${SITE_URL}/rss.xml`} />
    <link rel="llms" href="/llms.txt" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedCanonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={SITE_TITLE} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {isHomePage && <script type="application/ld+json" set:html={JSON.stringify(softwareAppSchema)} />}
    {isHomePage && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}

    <!-- Theme init: run before paint to avoid flash -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('chiba-theme');
        var theme = saved || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class="grain min-h-screen bg-chiba-bg text-chiba-text selection:bg-chiba-green selection:text-chiba-bg">
    <a href="#main-content" class="skip-link">Skip to content</a>
    <Navbar />
    <div id="main-content">
      <slot />
    </div>
  </body>
</html>
