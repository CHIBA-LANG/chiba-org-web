---
import { getCollection, render } from 'astro:content';
import DocsPost from '../../layouts/DocsPost.astro';
import { extractMarkdownDescription, extractMarkdownTitle } from '../../utils/content';

export async function getStaticPaths() {
  const docs = (await getCollection('chiba_level1_spec')).sort((left, right) =>
    left.id.localeCompare(right.id, undefined, { numeric: true })
  );
  const linkedDocs = docs.map((doc) => ({
    doc,
    title: doc.data.title ?? extractMarkdownTitle(doc.body ?? "", doc.id),
    href: `/docs/${doc.id}/`,
  }));

  return linkedDocs.map(({ doc }, index) => ({
    params: { slug: doc.id },
    props: {
      doc,
      previousDoc: linkedDocs[index - 1] ? { title: linkedDocs[index - 1].title, href: linkedDocs[index - 1].href } : undefined,
      nextDoc: linkedDocs[index + 1] ? { title: linkedDocs[index + 1].title, href: linkedDocs[index + 1].href } : undefined,
    },
  }));
}

const { doc, previousDoc, nextDoc } = Astro.props;
const { Content } = await render(doc);
const title = doc.data.title ?? extractMarkdownTitle(doc.body ?? "", doc.id);
const description = doc.data.description ?? extractMarkdownDescription(doc.body ?? "");
---

<DocsPost title={title} description={description} slug={doc.id} previousDoc={previousDoc} nextDoc={nextDoc}>
  <Content />
</DocsPost>