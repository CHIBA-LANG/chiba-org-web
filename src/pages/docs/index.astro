---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { extractMarkdownDescription, extractMarkdownTitle } from '../../utils/content';

const docs = (await getCollection('chiba_level1_spec')).map((entry) => ({
  ...entry,
  computedTitle: entry.data.title ?? extractMarkdownTitle(entry.body ?? "", entry.id),
  computedDescription: entry.data.description ?? extractMarkdownDescription(entry.body ?? ""),
}));

const groupedDocs = Object.entries(
  docs.reduce<Record<string, typeof docs>>((groups, doc) => {
    const [section = 'root'] = doc.id.split('/');
    groups[section] ??= [];
    groups[section].push(doc);
    return groups;
  }, {})
)
  .sort(([left], [right]) => left.localeCompare(right, undefined, { numeric: true }))
  .map(([section, entries]) => ({
    section,
    entries: entries.sort((left, right) => left.id.localeCompare(right.id, undefined, { numeric: true })),
  }));

function formatSectionName(section: string) {
  if (section === 'root') return 'Overview';
  return section.replace(/[-_]+/g, ' ');
}
---

<BaseLayout
  title="Docs"
  description="CHIBA level-1 specification inside the site, including core language, control flow, memory model, package system, and lowering notes."
>
  <main class="max-w-[1600px] mx-auto px-6 md:px-10 pt-30 pb-24">
    <section class="mb-12 border border-chiba-line bg-chiba-container overflow-hidden">
      <div class="px-6 md:px-8 py-8 md:py-10 bg-[linear-gradient(135deg,rgba(0,230,118,0.10),transparent_55%),linear-gradient(180deg,var(--color-chiba-container-high),var(--color-chiba-container))]">
        <div class="text-[10px] font-mono font-bold uppercase tracking-[0.24em] text-chiba-gray mb-4">CHIBA / DOCS / LEVEL-1</div>
        <h1 class="font-space text-5xl md:text-7xl font-bold tracking-[-0.05em] uppercase text-chiba-text mb-4">Docs</h1>
        <div class="grid grid-cols-1 lg:grid-cols-[1.6fr_1fr] gap-8 items-start">
          <div class="space-y-3 max-w-4xl text-lg leading-relaxed">
            <p class="text-chiba-text-dim">这里接入了站内版 CHIBA level-1 spec，包含 core language、control flow、memory model、package system、IR lowering 与配套设计说明。</p>
            <p class="text-chiba-gray">This page turns the level-1 spec into a navigable documentation surface, grouped by subsystem so readers can jump directly into the language boundary they need.</p>
          </div>
          <div class="grid grid-cols-2 gap-px border border-chiba-line bg-chiba-line text-xs font-mono uppercase tracking-[0.18em]">
            <div class="bg-chiba-container p-4">
              <div class="text-chiba-gray mb-2">Sections</div>
              <div class="text-2xl text-chiba-green font-bold">{groupedDocs.length}</div>
            </div>
            <div class="bg-chiba-container p-4">
              <div class="text-chiba-gray mb-2">Pages</div>
              <div class="text-2xl text-chiba-green font-bold">{docs.length}</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 xl:grid-cols-[280px_1fr] gap-6 items-start">
      <details class="xl:hidden border border-chiba-line bg-chiba-container overflow-hidden">
        <summary class="px-5 py-4 cursor-pointer border-b border-chiba-line text-[10px] font-mono font-bold uppercase tracking-[0.22em] text-chiba-gray">
          Section Map
        </summary>
        <nav class="p-3 space-y-1 max-h-80 overflow-y-auto">
          {groupedDocs.map(({ section, entries }) => (
            <a href={`#${section}`} class="block px-3 py-3 border border-transparent hover:border-chiba-green/30 hover:bg-chiba-container-low transition-colors">
              <div class="text-[11px] font-mono uppercase tracking-[0.18em] text-chiba-green">{formatSectionName(section)}</div>
              <div class="text-xs text-chiba-gray mt-1">{entries.length} pages</div>
            </a>
          ))}
        </nav>
      </details>

      <aside class="hidden xl:block border border-chiba-line bg-chiba-container sticky top-28">
        <div class="px-5 py-4 border-b border-chiba-line text-[10px] font-mono font-bold uppercase tracking-[0.22em] text-chiba-gray">Section Map</div>
        <nav class="p-3 space-y-1">
          {groupedDocs.map(({ section, entries }) => (
            <a href={`#${section}`} class="block px-3 py-3 border border-transparent hover:border-chiba-green/30 hover:bg-chiba-container-low transition-colors">
              <div class="text-[11px] font-mono uppercase tracking-[0.18em] text-chiba-green">{formatSectionName(section)}</div>
              <div class="text-xs text-chiba-gray mt-1">{entries.length} pages</div>
            </a>
          ))}
        </nav>
      </aside>

      <div class="space-y-8">
        {groupedDocs.map(({ section, entries }) => (
          <section id={section} class="border border-chiba-line bg-chiba-container overflow-hidden">
            <header class="px-6 py-5 border-b border-chiba-line bg-chiba-container-high/60">
              <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3">
                <div>
                  <div class="text-[10px] font-mono font-bold uppercase tracking-[0.22em] text-chiba-gray mb-2">Spec Section</div>
                  <h2 class="font-space text-2xl md:text-3xl font-bold uppercase tracking-[-0.03em] text-chiba-text">{formatSectionName(section)}</h2>
                </div>
                <div class="text-xs font-mono uppercase tracking-[0.18em] text-chiba-gray">{entries.length} documents</div>
              </div>
            </header>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-chiba-line">
              {entries.map((doc) => (
                <a href={`/docs/${doc.id}`} class="group block bg-chiba-container p-5 hover:bg-chiba-container-low transition-colors min-h-44">
                  <div class="text-[10px] font-mono uppercase tracking-[0.18em] text-chiba-gray mb-3 border-b border-chiba-line pb-3">
                    {doc.id}
                  </div>
                  <h3 class="text-lg font-space font-bold uppercase tracking-[-0.02em] text-chiba-text group-hover:text-chiba-green transition-colors leading-tight mb-3">
                    {doc.computedTitle}
                  </h3>
                  <p class="text-sm text-chiba-text-dim leading-relaxed mb-4">{doc.computedDescription}</p>
                  <div class="text-[10px] text-chiba-gray font-bold uppercase tracking-[0.18em] flex items-center gap-1 group-hover:gap-2 transition-all mt-auto pt-4 border-t border-chiba-line">
                    Open Doc
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>