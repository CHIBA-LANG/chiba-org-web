---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog"
  description="Latest insights from the CHIBA team on deterministic systems, formal verification, and compiler engineering."
>
  <main class="max-w-5xl mx-auto px-6 pt-36 pb-24">
    <div class="mb-16">
      <div class="text-[10px] font-bold uppercase tracking-widest text-chiba-gray mb-4">CHIBA / INSIGHTS</div>
      <h1 class="font-space text-5xl md:text-6xl font-bold tracking-tighter text-chiba-text mb-4">Latest Insights</h1>
      <p class="text-chiba-text-dim text-lg">Tracking the frontier of deterministic systems engineering.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="block group">
          <div class="bg-chiba-container border border-chiba-container-high rounded-[24px] p-6 h-full hover:border-chiba-green/30 transition-all">
            {post.data.heroImage && (
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                class="w-full h-40 object-cover rounded-2xl mb-4"
              />
            )}
            <div class="text-[10px] font-bold uppercase tracking-widest text-chiba-gray mb-3">
              <FormattedDate date={post.data.pubDate} />
            </div>
            <h2 class="text-xl font-space font-bold text-chiba-text group-hover:text-chiba-green transition-colors mb-2 leading-tight">
              {post.data.title}
            </h2>
            {post.data.description && (
              <p class="text-xs text-chiba-text-dim leading-relaxed">{post.data.description}</p>
            )}
            <div class="mt-4 text-[10px] text-chiba-gray font-bold uppercase tracking-widest flex items-center gap-1 group-hover:gap-2 transition-all">
              Read
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </main>

  <footer class="border-t border-chiba-container-high py-8 text-center">
    <p class="text-[10px] text-chiba-gray uppercase tracking-widest">
      &copy; {new Date().getFullYear()} CHIBA Software Foundation
    </p>
  </footer>
</BaseLayout>
