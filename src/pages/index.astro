---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Pillars from '../components/Pillars.astro';
import CodeBlock from '../components/CodeBlock.astro';
import FAQGrid from '../components/FAQGrid.astro';
import BlogPostsSection from '../components/BlogPostsSection.astro';
import SoftwareFoundation from '../components/SoftwareFoundation.astro';
import ChibaLabs from '../components/ChibaLabs.astro';
import SponsorsLarge from '../components/SponsorsLarge.astro';
import CommunitySection from '../components/CommunitySection.astro';
import Vision from '../components/Vision.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<BaseLayout
  title="CHIBA"
  description="Metal-level functional zero runtime infrastructure. Deterministic compilation with Automated Theorem Proving for formal memory verification."
>
  <main class="max-w-[1600px] mx-auto pt-24 pb-16 px-6 md:px-10 grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-min">
    <Hero />
    <Pillars />
    <CodeBlock />
    <FAQGrid />
    <BlogPostsSection />
    <SoftwareFoundation />
    <ChibaLabs />
    <SponsorsLarge />
    <CommunitySection />
    <Vision />
  </main>
  <SiteFooter />
</BaseLayout>
